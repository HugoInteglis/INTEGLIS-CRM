rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable primitives
    function isSignedIn() {
      return request.auth != null;
    }

    // Clients Collection Rules
    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    // Deals Collection Rules
    match /deals/{dealId} {
      allow read, write: if isSignedIn();
    }

    // Quotes Collection Rules
    match /quotes/{quoteId} {
      allow read, write: if isSignedIn();
    }

    // Docs Collection Rules
    match /docs/{docId} {
      allow read, write: if isSignedIn();
    }

    // Tasks Collection Rules
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    // Trash Collection Rules
    match /trash/{trashId} {
      allow read, write: if isSignedIn();
    }
  }
}
